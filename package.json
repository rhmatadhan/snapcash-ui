{
  "name": "snapcash-ui",
  "version": "1.0.0",
  "description": "",
  "main": "tailwind.config.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/css/style.css --watch",
    "server": "browser-sync start --server '.' --files 'index.html, dist/css/*.css, src/js/*.js'",
    "dev": "concurrently \"npm run watch:css\" \"npm run server\"",
    "format": "prettier --write \".\" "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhmatadhan/snapcash-ui.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rhmatadhan/snapcash-ui/issues"
  },
  "homepage": "https://github.com/rhmatadhan/snapcash-ui#readme",
  "devDependencies": {
    "@iconify/tailwind": "^1.2.0",
    "autoprefixer": "^10.5.2",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19"
  }
}
